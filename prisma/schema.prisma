generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum PropertyType {
  APARTMENT
  VILLA
  INDEPENDENT_HOUSE
  PLOT
  PENTHOUSE
  STUDIO
  FARMHOUSE
}

enum ListingType {
  SALE
  RENT
}

enum PropertyStatus {
  ACTIVE
  DRAFT
  PENDING_REVIEW
  SOLD
  RENTED
  INACTIVE
}

enum UserRole {
  USER
  ADMIN
}

enum Facing {
  NORTH
  SOUTH
  EAST
  WEST
  NORTH_EAST
  NORTH_WEST
  SOUTH_EAST
  SOUTH_WEST
}

enum ConstructionStatus {
  READY_TO_MOVE
  UNDER_CONSTRUCTION
}

enum TransactionType {
  NEW
  RESALE
}

model Property {
  id            String         @id @default(cuid())
  title         String
  description   String?

  listingType   ListingType
  propertyType  PropertyType
  status        PropertyStatus @default(ACTIVE)

  // Pricing — stored in whole rupees (avoid float rounding issues)
  priceInRupees Int
  priceUnit     String?        // e.g. "month" for rent listings, null for sale

  areaSqft      Int

  locality      String
  city          String
  state         String
  pincode       String

  bedrooms      Int?
  bathrooms     Int?

  isFeatured    Boolean        @default(false)

  facing             Facing?
  hasBoundaryWall    Boolean?
  constructionStatus ConstructionStatus?
  roadWidthFeet      Int?
  openSides          Int?
  transactionType    TransactionType?
  highlights         String[]            @default([])
  features           String[]            @default([])

  images        PropertyImage[]

  owner         User?          @relation(fields: [ownerId], references: [id])
  ownerId       String?

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([city, locality])
  @@index([listingType, propertyType])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole  @default(USER)

  accounts      Account[]
  sessions      Session[]
  properties    Property[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PropertyImage {
  id          String   @id @default(cuid())
  url         String
  alt         String?
  sortOrder   Int      @default(0)
  isCover     Boolean  @default(false)

  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId  String

  @@index([propertyId])
}
